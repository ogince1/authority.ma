# PayPal Configuration
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
VITE_PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
VITE_PAYPAL_MODE=sandbox  # ou 'live' pour la production

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
VITE_STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Application Configuration
VITE_APP_NAME=Authority.ma
VITE_APP_URL=http://localhost:5178
VITE_APP_ENV=development

# Analytics (optionnel)
VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here

# Email Configuration (optionnel)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your_email@gmail.com
VITE_SMTP_PASS=your_app_password_here

# Storage Configuration
VITE_STORAGE_BUCKET=evidence-files
VITE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# Commission Configuration
VITE_PLATFORM_COMMISSION_RATE=0.10  # 10% de commission
VITE_MIN_TRANSACTION_AMOUNT=10      # Montant minimum en MAD
VITE_MAX_TRANSACTION_AMOUNT=10000   # Montant maximum en MAD

# Notification Configuration
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_NOTIFICATION_SOUND_ENABLED=true

# Security Configuration
VITE_SESSION_TIMEOUT=3600  # 1 heure en secondes
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_PASSWORD_MIN_LENGTH=8

# Feature Flags
VITE_ENABLE_DISPUTES=true
VITE_ENABLE_COMMISSIONS=true
VITE_ENABLE_URL_VALIDATION=true
VITE_ENABLE_AUTOMATIC_REFUNDS=true
VITE_ENABLE_ADVANCED_ANALYTICS=true 